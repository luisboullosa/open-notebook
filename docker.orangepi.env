# Docker environment configuration for Orange Pi (LAN deployment)

# API Configuration
# Comment out API_URL to auto-detect (works when accessing from same IP)
# If accessing from different device, uncomment and set Orange Pi's IP:
# API_URL=http://192.168.1.XXX:5055
INTERNAL_API_URL=http://localhost:5055

# rk-llama.cpp via openai-compatible provider (native systemd services)
# Chat server on port 8081, Embedding server on port 8082
OPENAI_COMPATIBLE_BASE_URL_LLM=http://localhost:8081/v1
OPENAI_COMPATIBLE_BASE_URL_EMBEDDING=http://localhost:8082/v1
OPENAI_COMPATIBLE_BASE_URL_STT=http://localhost:9100/v1
OPENAI_COMPATIBLE_BASE_URL_TTS=http://localhost:8969/v1
OPENAI_COMPATIBLE_API_KEY=not-required

# Disable Ollama (replaced by rk-llama.cpp)
ENABLE_OLLAMA=false

# Authentication
OPEN_NOTEBOOK_PASSWORD=your_secure_password_here
OPEN_NOTEBOOK_ENCRYPTION_KEY=your_64+_char_random_secret_here

# Whisper configuration
WHISPER_API_URL=http://localhost:9000
ENABLE_WHISPER=true

# Optional: Reduce worker concurrency for Orange Pi's limited resources
# WORKER_CONCURRENCY=1
