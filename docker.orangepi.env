# Docker environment configuration for Orange Pi (LAN deployment)

# API Configuration
# Comment out API_URL to auto-detect (works when accessing from same IP)
# If accessing from different device, uncomment and set Orange Pi's IP:
# API_URL=http://192.168.1.XXX:5055
INTERNAL_API_URL=http://localhost:5055

# Ollama Configuration
OLLAMA_API_BASE=http://localhost:11434

# Enable Ollama service (default true)
ENABLE_OLLAMA=true

# Authentication
OPEN_NOTEBOOK_PASSWORD=your_secure_password_here
OPEN_NOTEBOOK_ENCRYPTION_KEY=your_64+_char_random_secret_here

# Whisper configuration
WHISPER_API_URL=http://localhost:9000
ENABLE_WHISPER=true

# Piper TTS configuration  
PIPER_API_URL=http://localhost:10200
ENABLE_PIPER=true

# Optional: Reduce worker concurrency for Orange Pi's limited resources
# WORKER_CONCURRENCY=1
