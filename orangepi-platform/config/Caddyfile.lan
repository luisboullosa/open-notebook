{
	admin off
	servers {
		protocols h1 h2
	}
}

:8088 {
	handle /lan-ca.crt {
		root * /certs/lan
		rewrite * /lan-ca.crt
		header Content-Type application/x-x509-ca-cert
		file_server
	}

	handle /lan-ca.crl {
		root * /certs/lan
		rewrite * /lan-ca.crl
		header Content-Type application/pkix-crl
		file_server
	}

	handle {
		respond "Use /lan-ca.crt" 404
	}
}

https://:443 {
	tls /certs/lan/lan-server.crt /certs/lan/lan-server.key

	handle_path /stirling* {
		reverse_proxy stirling-pdf:8080
	}

	handle_path /llm/* {
		reverse_proxy host.docker.internal:8081
	}

	handle_path /embed/* {
		reverse_proxy host.docker.internal:8082
	}

	handle_path /whisper* {
		reverse_proxy whisper:9000
	}

	handle /lan-ca.crt {
		root * /certs/lan
		rewrite * /lan-ca.crt
		header Content-Type application/x-x509-ca-cert
		file_server
	}

	handle /lan-ca.crl {
		root * /certs/lan
		rewrite * /lan-ca.crl
		header Content-Type application/pkix-crl
		file_server
	}

	handle /api/* {
		reverse_proxy open_notebook:5055
	}

	handle {
		reverse_proxy open_notebook:8502
	}

	encode gzip

	log {
		output stdout
		format console
		level INFO
	}
}

https://:4444 {
	tls /certs/lan/lan-server.crt /certs/lan/lan-server.key

	reverse_proxy host.docker.internal:8504

	encode gzip

	log {
		output stdout
		format console
		level INFO
	}
}